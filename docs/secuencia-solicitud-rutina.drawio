<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Solicitud Rutina" id="seq-solicitud">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="SECUENCIA — Solicitud de Rutina Personalizada" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="480" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="l1" value="Cliente" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="55" width="90" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="l2" value="Entrenador" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="55" width="90" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="l3" value="Controller&#xa;(Requests + Routines)" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="55" width="140" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="l4" value="MongoDB" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="650" y="55" width="90" height="620" as="geometry"/>
        </mxCell>
        <mxCell id="l5" value="NotificationService" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="840" y="55" width="110" height="620" as="geometry"/>
        </mxCell>

        <!-- CLIENTE SOLICITA -->
        <mxCell id="box1" value="Cliente solicita rutina" style="shape=frame;whiteSpace=wrap;html=1;startSize=20;fillColor=none;strokeColor=#82b366;fontSize=11;fontStyle=1;rounded=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="15" y="100" width="360" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="m1" value="1. Completa formulario (edad, peso, objetivo...)" style="html=1;endArrow=classic;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="85" y="140" as="sourcePoint"/><mxPoint x="85" y="140" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" value="2. POST /api/routine-requests/" style="html=1;endArrow=classic;fontSize=10;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="85" y="175" as="sourcePoint"/><mxPoint x="470" y="175" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="3. RoutineRequest.create({estado:'Pendiente'})" style="html=1;endArrow=classic;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="470" y="210" as="sourcePoint"/><mxPoint x="695" y="210" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ENTRENADOR REVISA -->
        <mxCell id="box2" value="Entrenador revisa y aprueba" style="shape=frame;whiteSpace=wrap;html=1;startSize=20;fillColor=none;strokeColor=#d6b656;fontSize=11;fontStyle=1;rounded=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="15" y="260" width="360" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="m4" value="4. GET /api/routine-requests/ (pendientes)" style="html=1;endArrow=classic;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="245" y="300" as="sourcePoint"/><mxPoint x="470" y="300" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5" value="5. PUT .../approve → estado:'En revision'" style="html=1;endArrow=classic;fontSize=10;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="245" y="340" as="sourcePoint"/><mxPoint x="470" y="340" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ENTRENADOR CREA RUTINA -->
        <mxCell id="box3" value="Entrenador crea rutina y asigna" style="shape=frame;whiteSpace=wrap;html=1;startSize=20;fillColor=none;strokeColor=#9673a6;fontSize=11;fontStyle=1;rounded=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="15" y="400" width="360" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="m6" value="6. POST /api/routines/ (crear rutina)" style="html=1;endArrow=classic;fontSize=10;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="245" y="440" as="sourcePoint"/><mxPoint x="470" y="440" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" value="7. Routine.create()" style="html=1;endArrow=classic;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="470" y="470" as="sourcePoint"/><mxPoint x="695" y="470" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m8" value="8. PUT .../assign-routine {rutinaId}" style="html=1;endArrow=classic;fontSize=10;fontStyle=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="245" y="500" as="sourcePoint"/><mxPoint x="470" y="500" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m9" value="9. AssignedRoutine.create() + estado:'Rutina asignada'" style="html=1;endArrow=classic;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="470" y="535" as="sourcePoint"/><mxPoint x="695" y="535" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- NOTIFICACIÓN -->
        <mxCell id="m10" value="10. Notificar cliente ('Tu rutina está lista')" style="html=1;endArrow=classic;fontSize=10;fontColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="470" y="575" as="sourcePoint"/><mxPoint x="895" y="575" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m11" value="11. Cliente ve su rutina en /my-routine" style="html=1;endArrow=classic;fontSize=10;fontColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="695" y="610" as="sourcePoint"/><mxPoint x="85" y="610" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="Membresías" id="seq-membresias">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="750" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="SECUENCIA — Gestión de Membresías" style="text;html=1;align=center;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="10" width="400" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="l1" value="Admin /&#xa;Entrenador" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="55" width="100" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="l2" value="MembershipController" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="55" width="130" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="l3" value="MongoDB&#xa;(Models)" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="580" y="55" width="100" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="l4" value="NotificationService" style="shape=umlLifeline;perimeter=lifelinePerimeter;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;size=40;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="770" y="55" width="100" height="550" as="geometry"/>
        </mxCell>

        <!-- CREAR MEMBRESÍA -->
        <mxCell id="box1" value="Crear Membresía" style="shape=frame;whiteSpace=wrap;html=1;startSize=20;fillColor=none;strokeColor=#82b366;fontSize=11;fontStyle=1;rounded=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="95" width="860" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="m1" value="1. Selecciona cliente + plan + método de pago" style="html=1;endArrow=classic;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="110" y="135" as="sourcePoint"/><mxPoint x="365" y="135" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" value="2. Client.findOne({email}) + Plan.findById()" style="html=1;endArrow=classic;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="365" y="175" as="sourcePoint"/><mxPoint x="630" y="175" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="3. Membership.create() + Payment.create()" style="html=1;endArrow=classic;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="365" y="215" as="sourcePoint"/><mxPoint x="630" y="215" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4" value="4. notifyAdminsAndTrainers()" style="html=1;endArrow=classic;fontSize=11;fontColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="365" y="250" as="sourcePoint"/><mxPoint x="820" y="250" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- RENOVAR MEMBRESÍA -->
        <mxCell id="box2" value="Renovar Membresía" style="shape=frame;whiteSpace=wrap;html=1;startSize=20;fillColor=none;strokeColor=#d6b656;fontSize=11;fontStyle=1;rounded=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="295" width="860" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="m5" value="5. Selecciona membresía + método de pago" style="html=1;endArrow=classic;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="110" y="335" as="sourcePoint"/><mxPoint x="365" y="335" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" value="6. Actualiza fechas + Payment.create()" style="html=1;endArrow=classic;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="365" y="375" as="sourcePoint"/><mxPoint x="630" y="375" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- CANCELAR MEMBRESÍA -->
        <mxCell id="box3" value="Cancelar Membresía" style="shape=frame;whiteSpace=wrap;html=1;startSize=20;fillColor=none;strokeColor=#b85450;fontSize=11;fontStyle=1;rounded=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="450" width="860" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="m7" value="7. Selecciona membresía a cancelar" style="html=1;endArrow=classic;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="110" y="490" as="sourcePoint"/><mxPoint x="365" y="490" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m8" value="8. estado = 'cancelada' + save()" style="html=1;endArrow=classic;fontSize=11;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="365" y="530" as="sourcePoint"/><mxPoint x="630" y="530" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

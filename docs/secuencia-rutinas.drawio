        <mxCell id="box2" value="Construir y guardar rutina" style="shape=frame;whiteSpace=wrap;html=1;startSize=20;fillColor=none;strokeColor=#82b366;fontSize=11;fontStyle=1;rounded=1;dashed=1;" vertex="1" parent="1">
